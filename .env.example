# Skopiuj ten plik jako .env.local i wpisz prawdziwe wartości.
# NIGDY nie commituj .env.local — jest w .gitignore.

# ========= Supabase =========
# Dashboard: https://supabase.com/dashboard/project/<project-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# UWAGA: SERVICE_ROLE_KEY pomija RLS — używaj wyłącznie po stronie serwera.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========= Stripe =========
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ========= App =========
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kubkomania

# ========= Admin =========
# Tajny URL panelu admina (min. 6 znaków). Wymyśl coś losowego.
# Panel będzie dostępny pod http://domena/${ADMIN_URL_SECRET}
ADMIN_URL_SECRET=zmien-mnie-na-cos-losowego
